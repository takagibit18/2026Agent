# 复制本文件为同目录下的 .env 后填写（.env 已被 git 忽略）
#
# 加载规则：先读 embedding_test/.env，再读本目录 .env；同名变量以本目录 .env 为准。
# 若只改了上级 .env，但本目录 .env 里仍留着旧的 DASHSCOPE_API_KEY，会继续用旧的 → 易触发 401。

# ---------- 通义千问向量（DashScope OpenAI 兼容模式）----------
# 在阿里云百炼 / DashScope 控制台创建 API-Key
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=

# 模型名，例如 text-embedding-v3（以控制台当前可用名为准）
QWEN_EMBEDDING_MODEL=text-embedding-v3

# 兼容模式 Base URL（北京地域默认如下；新加坡等国际域见下行注释）
DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际（新加坡）示例：
# DASHSCOPE_COMPAT_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# 可选：向量维度（如 1024、768；不填则使用接口默认）
# QWEN_EMBEDDING_DIMENSIONS=1024

# 单次请求最多嵌入的文本条数（DashScope 通常上限为 10，超过会 400）
# QWEN_EMBEDDING_BATCH_SIZE=10

# ---------- 本地 BGE-M3（FlagEmbedding）----------
# HuggingFace 模型 ID 或本地已缓存的同名路径
BGE_M3_MODEL=BAAI/bge-m3

# 是否使用半精度（需 GPU 且驱动支持；CPU 建议 false）
BGE_USE_FP16=false
